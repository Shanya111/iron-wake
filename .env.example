# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Прокси для соединения с Telegram (только на сервере, урок 5.12).
# Локально оставь пустым — бот пойдёт к Telegram напрямую.
# На сервере: socks5://127.0.0.1:1080 (прокси из урока 5.09).
BOT_PROXY=

# API-ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# ID чата или канала, куда отправлять уведомления
# Узнать можно через @userinfobot или @getidsbot
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram ID администратора (для команды /broadcast)
# Узнать свой ID можно командой /myid в боте
ADMIN_ID=

# Токен платёжной системы для Telegram Payments
# Получить у @BotFather → Bot Settings → Payments
# Для теста используй токен от Stripe TEST или ЮKassa тестовый
PAYMENT_TOKEN=

# Источник данных (если используешь ccxt)
# Название биржи: binance, bybit, okx и т.д.
EXCHANGE=binance

# API-ключи биржи (если нужен приватный доступ)
# Для публичных данных по объёмам — не обязательны
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Порог объёма для уведомления (в USD)
VOLUME_THRESHOLD=1000000

# Интервал проверки в секундах
CHECK_INTERVAL=60
