# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Прокси для соединения с Telegram (только на сервере, урок 5.12).
# Локально оставь пустым — бот пойдёт к Telegram напрямую.
# На сервере: socks5://127.0.0.1:1080 (прокси из урока 5.09).
BOT_PROXY=

# Прокси для бирж (CCXT) — нужен, если Binance/биржа блокирует регион (HTTP 451).
# Должен быть в РАЗРЕШЁННОЙ стране (прокси из РФ не поможет — Binance её блокирует).
# Поддерживает http(s):// и socks5://. Пусто — биржа запрашивается напрямую.
CCXT_PROXY=

# API-ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# Модель OpenRouter. Должна быть реальной (список: openrouter.ai/models).
# Бесплатные оканчиваются на :free. Пусто — берётся значение по умолчанию из кода.
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ID чата или канала, куда отправлять уведомления
# Узнать можно через @userinfobot или @getidsbot
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram ID администратора (для команды /broadcast)
# Узнать свой ID можно командой /myid в боте
ADMIN_ID=

# Токен платёжной системы для Telegram Payments
# Получить у @BotFather → Bot Settings → Payments
# Для теста используй токен от Stripe TEST или ЮKassa тестовый
PAYMENT_TOKEN=

# Данные по крипте берутся через CCXT с публичных эндпоинтов бирж — API-ключи НЕ
# нужны. Биржа и символ заданы по инструментам в instruments.py (поле "ccxt"):
# BTC/ETH/SOL — binance, TON — bybit. Пороги стратегий — в config.py и команде
# /settings. Интервалы анализа/мониторинга — тоже в config.py.
