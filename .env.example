# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# API-ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# ID чата или канала, куда отправлять уведомления
# Узнать можно через @userinfobot или @getidsbot
TELEGRAM_CHAT_ID=your_chat_id_here

# Источник данных (если используешь ccxt)
# Название биржи: binance, bybit, okx и т.д.
EXCHANGE=binance

# API-ключи биржи (если нужен приватный доступ)
# Для публичных данных по объёмам — не обязательны
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Порог объёма для уведомления (в USD)
VOLUME_THRESHOLD=1000000

# Интервал проверки в секундах
CHECK_INTERVAL=60
